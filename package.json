{
  "name": "s3mulator",
  "version": "1.0.0",
  "description": "A CLI S3 emulator for local development",
  "license": "MIT",
  "engines": { "node": ">=18.3" },
  "author": "Ian Zamojc",
  "repository": {
    "type": "git",
    "url": "https://github.com/Soviut/s3mulator.git"
  },
  "keywords": ["s3", "aws", "emulator", "simulator", "mock", "local", "cli", "hono"],
  "bin": {
    "s3mulator": "dist/server.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc && tsc-alias",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.{js,ts,json}\"",
    "prepublishOnly": "npm run build && npm test"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.1",
    "hono": "^4.12.18"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.0.0",
    "@aws-sdk/s3-request-presigner": "^3.0.0",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.3",
    "prettier-eslint-cli": "^8.0.1",
    "tsc-alias": "^1.8.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
